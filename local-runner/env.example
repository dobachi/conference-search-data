# Conference Search ローカルランナー設定
# コピー先: ~/.config/conf-search/runner.env

# リポジトリパス
CONF_SEARCH_REPO=$HOME/Sources/DevConferenceSearch/projects/conference-search-data

# ログディレクトリ
CONF_SEARCH_LOG_DIR=$HOME/.local/share/conf-search/logs

# Claude CLI 引数
CONF_SEARCH_CLAUDE_ARGS="--allowedTools Bash,Read,Write,Edit,Glob,Grep,WebSearch,WebFetch --max-turns 60"

# タイムゾーン
TZ=Asia/Tokyo
